# ============================================================
# Smart Traffic Public Issue Reporting System – Environment
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/traffic_issues

# ── JWT / Session ────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-me

# ── Manus OAuth (existing) ───────────────────────────────────
OAUTH_SERVER_URL=https://oauth-portal.example.com
VITE_OAUTH_PORTAL_URL=https://oauth-portal.example.com
VITE_APP_ID=your-manus-app-id
OWNER_OPEN_ID=your-manus-owner-open-id

# ── Google OAuth ─────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable the "Google+ API" or "Google Identity" and set up
# OAuth 2.0 credentials. Add the redirect URI below to the
# "Authorised redirect URIs" list in the Google Cloud Console.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# ── Email / OTP (SMTP) ───────────────────────────────────────
# For Gmail, use an App Password (not your regular password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@traffic-system.com

# ── Admin account ────────────────────────────────────────────
# This email is automatically granted the 'admin' role on first sign-in.
ADMIN_EMAIL=saisumansamantaray184@gmail.com

# ── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── File Storage (optional – AWS S3 compatible) ──────────────
# Leave blank to disable image uploads.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ── Built-in Forge API (optional – AI features) ──────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
