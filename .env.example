# Environment Variables
# Copy this file to .env and fill in the values before running the app.

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL/PostgreSQL connection string.
# For local development: mysql://user:password@localhost:3306/smart_traffic
# For production (Neon): mysql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random string used to sign JWT session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── OAuth (Manus) ───────────────────────────────────────────────────────────
# Application ID issued by the Manus OAuth provider.
VITE_APP_ID=

# Base URL of the Manus OAuth server.
OAUTH_SERVER_URL=https://api.manus.im

# ─── File Storage (Manus Forge / S3-compatible) ───────────────────────────────
# Base URL of the Forge storage API.
BUILT_IN_FORGE_API_URL=

# API key for authenticating with the Forge storage service.
BUILT_IN_FORGE_API_KEY=

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
# Manus OpenID of the user who should be granted admin privileges on first run.
OWNER_OPEN_ID=

# Display name for the admin user.
OWNER_NAME=
